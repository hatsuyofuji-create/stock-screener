# ====== jp-sector-flow 環境変数サンプル ======
# このファイルを .env にコピーして、値を記入してください。
# .env は .gitignore 済みなのでコミットされません。

# データ提供元: mock（鍵不要・動作確認用） または jquants（本番）
PROVIDER=mock

# ---- J-Quants（PROVIDER=jquants のとき必要） ----
# J-Quants はリフレッシュトークン → IDトークン → Bearer 認証方式です。
# ダッシュボードで発行される「リフレッシュトークン」を入れてください。
# （メール/パスワードから自動発行する場合は下2つを使います）
JQUANTS_REFRESH_TOKEN=
# もしくはメールアドレス＋パスワード（リフレッシュトークンを自動取得します）
JQUANTS_MAILADDRESS=
JQUANTS_PASSWORD=
# Light プランのベースURL（通常は変更不要）
JQUANTS_BASE=https://api.jquants.com/v1
# 取得する営業日数（売買代金の推移グラフの期間）。約1年＝250営業日。多いほどAPI呼び出しが増えます。
JQUANTS_LOOKBACK_DAYS=250

# ---- LINE 通知（未設定ならコンソール出力に自動フォールバック） ----
LINE_CHANNEL_ACCESS_TOKEN=
LINE_USER_ID=
