# ====== jp-sector-flow 環境変数サンプル ======
# このファイルを .env にコピーして、値を記入してください。
# .env は .gitignore 済みなのでコミットされません。

# データ提供元: mock（鍵不要・動作確認用） または jquants（本番）
PROVIDER=mock

# ---- J-Quants（PROVIDER=jquants のとき必要・V2 APIキー方式） ----
# V2 はダッシュボードで発行する「APIキー」を x-api-key ヘッダで送るだけ。
# （2025-12-22 以降のアカウントは V2 のみ。旧トークン方式は廃止）
JQUANTS_API_KEY=
# V2 のベースURL（通常は変更不要）
JQUANTS_BASE=https://api.jquants.com/v2
# 取得する営業日数（売買代金の推移グラフの期間）。約1年＝250営業日。多いほどAPI呼び出しが増えます。
JQUANTS_LOOKBACK_DAYS=250

# ---- LINE 通知（未設定ならコンソール出力に自動フォールバック） ----
LINE_CHANNEL_ACCESS_TOKEN=
LINE_USER_ID=
